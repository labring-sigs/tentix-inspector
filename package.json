{
  "name": "tentix-inspector",
  "version": "2.6.0",
  "description": "Tentix plugin for Sealos namespace diagnostics and support-ticket triage",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "npm run dev:http",
    "start": "npm run start:http",
    "start:http": "NODE_ENV=production node dist/server/http-server.js",
    "start:client": "node dist/client/index.js",
    "dev:http": "NODE_ENV=development ts-node src/server/http-server.ts",
    "dev:client": "ts-node src/client/index.ts",
    "watch": "tsc --watch"
  },
  "keywords": [
    "tentix",
    "sealos",
    "kubernetes",
    "diagnostics",
    "inspector"
  ],
  "author": "Sealos SRE Team",
  "license": "MIT",
  "dependencies": {
    "@kubernetes/client-node": "^0.20.0",
    "@langchain/core": "^1.1.17",
    "@langchain/langgraph": "^1.1.2",
    "@langchain/openai": "^1.2.3",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.6.1",
    "express": "^5.0.1",
    "ssh2": "^1.15.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/ssh2": "^1.15.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
